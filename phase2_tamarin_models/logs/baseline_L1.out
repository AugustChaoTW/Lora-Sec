theory LoRaMesher_Baseline

begin

// Function signature and definition of the equational theory E

functions: data/3, fst/1, hello/3, pair/2, snd/1
equations: fst(<x.1, x.2>) = x.1, snd(<x.1, x.2>) = x.2

rule (modulo E) Node_Init:
   [ Fr( ~id ), Fr( ~psk ), Fr( ~seq ) ]
  --[ NodeInit( ~id ), HonestNode( ~id ), PSKInit( ~id, ~psk ) ]->
   [
   !Node( ~id, 'honest' ), !Honest( ~id ), !PSK( ~id, ~psk ),
   !HelloSeq( ~id, ~seq ), !Neighbor( ~id, ~id )
   ]

  /* has exactly the trivial AC variant */

rule (modulo E) Hello_Broadcast:
   [ !Node( n, 'honest' ), !HelloSeq( n, seq ) ]
  --[ HelloSent( n, 'zero', seq ) ]->
   [ Out( hello(n, 'zero', seq) ) ]

  /* has exactly the trivial AC variant */

rule (modulo E) Route_Update:
   [
   In( hello(src, metric, seq_new) ), !Node( dst, 'honest' ),
   !Neighbor( dst, dst )
   ]
  --[
  RouteUpdate( dst, src, metric, seq_new ),
  RouteAccepted( dst, src, metric, src, seq_new )
  ]->
   [ !RouteTable( dst, src, metric, src, seq_new ) ]

  /* has exactly the trivial AC variant */

rule (modulo E) Data_Forward:
   [
   In( data(src, dst, payload) ), !Node( forwarder, 'honest' ),
   !RouteTable( forwarder, dst, metric, nextHop, seq )
   ]
  --[ Forward( forwarder, src, dst, nextHop ) ]->
   [ Out( data(src, dst, payload) ) ]

  /* has exactly the trivial AC variant */

rule (modulo E) Compromise_Node:
   [
   !Node( n, 'honest' ), !PSK( n, psk ),
   !RouteTable( n, dst, metric, nh, seq )
   ]
  --[ Compromise( n ), Compromised( n ) ]->
   [ Out( psk ), Out( <n, dst, metric, nh, seq> ) ]

  /* has exactly the trivial AC variant */

lemma L1_RouteMetricAuthenticity_Baseline:
  all-traces
  "∀ node dst metric nh seq #i.
    (((RouteAccepted( node, dst, metric, nh, seq ) @ #i) ∧
      (∃ #h. HonestNode( node ) @ #h)) ∧
     (∃ #d. HonestNode( dst ) @ #d)) ⇒
    (∃ #j. (HelloSent( dst, 'zero', seq ) @ #j) ∧ (#j < #i))"
/*
guarded formula characterizing all counter-examples:
"∃ node dst metric nh seq #i.
  (RouteAccepted( node, dst, metric, nh, seq ) @ #i)
 ∧
  (∃ #h. (HonestNode( node ) @ #h)) ∧
  (∃ #d. (HonestNode( dst ) @ #d)) ∧
  (∀ #j. (HelloSent( dst, 'zero', seq ) @ #j) ⇒ ¬(#j < #i))"
*/
simplify
solve( !Node( ~id.1, 'honest' ) ▶₁ #i )
  case Node_Init
  solve( !Neighbor( ~id.1, ~id.1 ) ▶₂ #i )
    case Node_Init
    solve( !KU( hello(~id, metric, seq.2) ) @ #vk )
      case c_hello
      solve( !KU( ~id ) @ #vk.1 )
        case Compromise_Node_case_1
        solve( !KU( hello(dst, metric.1, seq.3) ) @ #vk.4 )
          case Hello_Broadcast
          SOLVED // trace found
        qed
      qed
    qed
  qed
qed

