theory LoRaMesher_Patched

begin

// Function signature and definition of the equational theory E

functions: fst/1, hmac/2, pair/2, snd/1
equations: fst(<x.1, x.2>) = x.1, snd(<x.1, x.2>) = x.2

rule (modulo E) Node_Init:
   [ Fr( ~id ), Fr( ~psk ), Fr( ~seq ) ]
  --[ NodeInit( ~id ), HonestNode( ~id ), PSKInit( ~id, ~psk ) ]->
   [
   !Node( ~id, 'honest' ), !Honest( ~id ), !PSK( ~id, ~psk ),
   !HelloSeq( ~id, ~seq ), !MetricVersion( ~id, ~id, 'v0' ),
   !Neighbor( ~id, ~id )
   ]

  /* has exactly the trivial AC variant */

rule (modulo E) Hello_Broadcast_Auth:
   [
   !Node( n, 'honest' ), !Honest( n ), !HelloSeq( n, seq ), !PSK( n, psk ),
   !MetricVersion( n, n, 'v0' )
   ]
  --[ HelloSent( n, 'zero', seq ), HMACGenerated( n, 'zero', seq, 'v0' )
  ]->
   [ Out( <n, 'zero', seq, n, 'v0', hmac(<n, 'zero', seq, n, 'v0'>, psk)> )
   ]

  /* has exactly the trivial AC variant */

rule (modulo E) Route_Update_Verify:
   [
   In( <src, metric, seq_new, nextHop, 'v0', 
        hmac(<src, metric, seq_new, nextHop, 'v0'>, psk_src)>
   ),
   !Node( dst, 'honest' ), !Neighbor( dst, dst ), !Honest( src ),
   !PSK( src, psk_src ), !MetricVersion( src, src, 'v0' )
   ]
  --[
  RouteUpdate( dst, src, metric, seq_new ),
  HMACVerified( dst, src, metric, seq_new ),
  RouteAccepted( dst, src, metric, nextHop, seq_new, 'v0' )
  ]->
   [ !RouteTable( dst, src, metric, nextHop, seq_new, 'v0' ) ]

  /* has exactly the trivial AC variant */

rule (modulo E) MetricVersion_Increment:
   [ !MetricVersion( n, n, 'v0' ) ]
  --[ MetricVersionIncrement( n, 'v0' ) ]->
   [ !MetricVersion( n, n, 'v0' ) ]

  // loop breaker: [0]
  /* has exactly the trivial AC variant */

rule (modulo E) Data_Forward:
   [
   In( <src, dst, payload> ), !Node( forwarder, 'honest' ),
   !RouteTable( forwarder, dst, metric, nextHop, seq, ver )
   ]
  --[ Forward( forwarder, src, dst, nextHop ) ]->
   [ Out( <src, dst, payload> ) ]

  /* has exactly the trivial AC variant */

rule (modulo E) Compromise_Node:
   [
   !Node( n, 'honest' ), !PSK( n, psk ),
   !RouteTable( n, dst, metric, nh, seq, ver )
   ]
  --[ Compromise( n ), Compromised( n ) ]->
   [ Out( psk ), Out( <n, dst, metric, nh, seq, ver> ) ]

  /* has exactly the trivial AC variant */

lemma L1_RouteMetricAuthenticity_Patched:
  all-traces
  "∀ node dst metric nh seq ver #i.
    ((((RouteAccepted( node, dst, metric, nh, seq, ver ) @ #i) ∧
       (∃ #h1. HonestNode( node ) @ #h1)) ∧
      (∃ #h2. HonestNode( dst ) @ #h2)) ∧
     (¬(∃ #c. Compromised( dst ) @ #c))) ⇒
    (∃ #j. (HelloSent( dst, 'zero', seq ) @ #j) ∧ (#j < #i))"
/*
guarded formula characterizing all counter-examples:
"∃ node dst metric nh seq ver #i.
  (RouteAccepted( node, dst, metric, nh, seq, ver ) @ #i)
 ∧
  (∃ #h1. (HonestNode( node ) @ #h1)) ∧
  (∃ #h2. (HonestNode( dst ) @ #h2)) ∧
  (∀ #c. (Compromised( dst ) @ #c) ⇒ ⊥) ∧
  (∀ #j. (HelloSent( dst, 'zero', seq ) @ #j) ⇒ ¬(#j < #i))"
*/
simplify
solve( !Node( ~id.1, 'honest' ) ▶₁ #i )
  case Node_Init
  solve( !Neighbor( ~id, ~id ) ▶₂ #i )
    case Node_Init
    solve( !Honest( ~id.1 ) ▶₃ #i )
      case Node_Init
      solve( !PSK( ~id.1, psk_src ) ▶₄ #i )
        case Node_Init
        solve( !MetricVersion( ~id.1, ~id.1, 'v0' ) ▶₅ #i )
          case MetricVersion_Increment
          solve( !KU( ~id.1 ) @ #vk.1 )
            case Compromise_Node_case_1
            by contradiction /* from formulas */
          next
            case Compromise_Node_case_2
            by contradiction /* from formulas */
          next
            case Hello_Broadcast_Auth_case_1
            solve( !KU( hmac(<~id.1, metric, seq.2, nh, 'v0'>, ~psk.1) ) @ #vk.10 )
              case Hello_Broadcast_Auth
              by contradiction /* from formulas */
            next
              case c_hmac
              solve( !KU( ~psk.1 ) @ #vk.15 )
